{
  "sortedMiddleware": [
    "/"
  ],
  "middleware": {
    "/": {
      "files": [
        "prerender-manifest.js",
        "server/edge-runtime-webpack.js",
        "server/middleware.js"
      ],
      "name": "middleware",
      "page": "/",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/admin(.json)?[\\/#\\?]?$",
          "originalSource": "/admin"
        },
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/admin\\/dashboard(.json)?[\\/#\\?]?$",
          "originalSource": "/admin/dashboard"
        },
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/admin\\/dashboard\\/create-farmer(.json)?[\\/#\\?]?$",
          "originalSource": "/admin/dashboard/create-farmer"
        },
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/admin\\/dashboard\\/create-farmer\\/created-farmer(.json)?[\\/#\\?]?$",
          "originalSource": "/admin/dashboard/create-farmer/created-farmer"
        },
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/admin\\/dashboard\\/contact(.json)?[\\/#\\?]?$",
          "originalSource": "/admin/dashboard/contact"
        },
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/admin\\/dashboard\\/customers(.json)?[\\/#\\?]?$",
          "originalSource": "/admin/dashboard/customers"
        }
      ],
      "wasm": [],
      "assets": []
    }
  },
  "functions": {},
  "version": 2
}